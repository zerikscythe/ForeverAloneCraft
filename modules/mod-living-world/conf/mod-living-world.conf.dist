# Living world configuration.

###################################################################################################
# ACCOUNT-ALT ITEM RECOVERY POLICY
#
#    LivingWorld.AccountAlt.EnableInventorySync
#        Allow clone-to-source inventory bag sync during bot dismiss and startup recovery.
#        Enabled by default so account alts keep persistent inventory state with
#        their source character across spawn, dismiss, and recovery flows.
#
#        Default: 1 (enabled)
#
#    LivingWorld.AccountAlt.EnableBankSync
#        Allow clone-to-source bank bag sync during bot dismiss and startup recovery.
#        Enabled by default so account alts keep persistent bank state with
#        their source character across spawn, dismiss, and recovery flows.
#
#        Default: 1 (enabled)
###################################################################################################

LivingWorld.AccountAlt.EnableInventorySync = 1
LivingWorld.AccountAlt.EnableBankSync = 1
